model serviceCategory {
  id                 Int                  @id @default(autoincrement())
  category           RoleService          @unique @default(service)
  services           services[]
  serviceSubCategory serviceSubCategory[]
}

model serviceSubCategory {
  id                      Int                       @id @default(autoincrement())
  subCategory             String
  subCategoryCover        String
  services                services[]
  serviceChildrenCategory serviceChildrenCategory[]
  serviceCategory         serviceCategory?          @relation(fields: [serviceCategoryId], references: [id])
  serviceCategoryId       Int?
}

model serviceChildrenCategory {
  id                   Int                 @id @default(autoincrement())
  childrenCategory     String
  services             services[]
  serviceSubCategory   serviceSubCategory? @relation(fields: [serviceSubCategoryId], references: [id])
  serviceSubCategoryId Int?
}

model services {
  id                        Int                      @id @default(autoincrement())
  title                     String
  content                   String                   @db.Text
  description               String?                  @db.Text
  image                     String?
  poached                   String                   @default("1111") @db.VarChar(10)
  duplicate                 Boolean                  @default(false)
  slug                      String                   @unique
  status                    RoleStatusService        @default(ide)
  reseller                  Boolean                  @default(false)
  sponsor                   Boolean                  @default(false)
  createdAt                 DateTime                 @default(now())
  updatedAt                 DateTime                 @updatedAt
  user                      users                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId                    String
  serviceReviews            serviceReviews[]
  serviceViews              serviceViews[]
  serviceSales              serviceSales[]
  orders                    orders[]
  serviceCategory           serviceCategory?         @relation(fields: [serviceCategoryId], references: [id])
  serviceCategoryId         Int?
  serviceSubCategory        serviceSubCategory?      @relation(fields: [serviceSubCategoryId], references: [id])
  serviceSubCategoryId      Int?
  serviceChildrenCategory   serviceChildrenCategory? @relation(fields: [serviceChildrenCategoryId], references: [id])
  serviceChildrenCategoryId Int?
}

model serviceSales {
  id         Int       @id @default(autoincrement())
  title      String
  price      Int
  services   services? @relation(fields: [servicesId], references: [id])
  servicesId Int?
  orders     orders[]
}

model serviceViews {
  id         Int       @id @default(autoincrement())
  user       users     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  services   services? @relation(fields: [servicesId], references: [id])
  servicesId Int?
}

model serviceReviews {
  id         Int       @id @default(autoincrement())
  content    String?
  level      Int
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  user       users     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  services   services? @relation(fields: [servicesId], references: [id])
  servicesId Int?
}

enum RoleService {
  service
  product
}

enum RoleStatusService {
  cancel
  success
  ide
  error
}
