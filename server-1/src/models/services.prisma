model serviceCategory {
  id          Int                  @id @default(autoincrement())
  category    String
  subCategory serviceSubCategory[]
  services    services[]
}

model serviceSubCategory {
  id                Int              @id @default(autoincrement())
  subCategory       String
  services          services[]
  serviceCategory   serviceCategory? @relation(fields: [serviceCategoryId], references: [id])
  serviceCategoryId Int?
}

model services {
  id                   Int                 @id @default(autoincrement())
  title                String
  content              String              @db.Text
  description          String?             @db.Text
  image                String?
  poached              String              @default("1111") @db.VarChar(10)
  duplicate            Boolean             @default(false)
  slug                 String              @unique
  published            Boolean             @default(false)
  reseller             Boolean             @default(false)
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  user                 users               @relation(fields: [userId], references: [id])
  userId               String
  serviceReviews       serviceReviews[]
  serviceLikes         serviceLikes[]
  serviceViews         serviceViews[]
  servicePomments      serviceComments[]
  serviceCategory      serviceCategory?    @relation(fields: [serviceCategoryId], references: [id])
  serviceCategoryId    Int?
  serviceSubCategory   serviceSubCategory? @relation(fields: [serviceSubCategoryId], references: [id])
  serviceSubCategoryId Int?
  serviceSales         serviceSales[]
  orders               orders[]
}

model serviceLikes {
  id         Int       @id @default(autoincrement())
  user       users     @relation(fields: [userId], references: [id])
  userId     String
  services   services? @relation(fields: [servicesId], references: [id])
  servicesId Int?
}

model serviceSales {
  id         Int       @id @default(autoincrement())
  title      String
  price      Int
  services   services? @relation(fields: [servicesId], references: [id])
  servicesId Int?
  orders     orders[]
}

model serviceViews {
  id         Int       @id @default(autoincrement())
  user       users     @relation(fields: [userId], references: [id])
  userId     String
  services   services? @relation(fields: [servicesId], references: [id])
  servicesId Int?
}

model serviceComments {
  id         Int       @id @default(autoincrement())
  content    String    @unique
  user       users     @relation(fields: [userId], references: [id])
  userId     String
  services   services? @relation(fields: [servicesId], references: [id])
  servicesId Int?
}

model serviceReviews {
  id         Int       @id @default(autoincrement())
  content    String    @unique
  level      Int
  user       users     @relation(fields: [userId], references: [id])
  userId     String
  services   services? @relation(fields: [servicesId], references: [id])
  servicesId Int?
}
